---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TokiGig',
  description = 'Operator-first systems for clear, reliable execution.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-bg-default text-text-primary">
    <slot />
  </body>
</html>