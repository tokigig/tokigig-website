---
// PillarSection.astro
// Section 3 — Pillars / Why Now
// Addresses "why do I need an AI workforce" fear BEFORE selling features.
// Structure: tension headline → fear statements → 3 cards with animated SVG icons
---

<section class="pillar-section">

  <!-- ── Section intro ──────────────────────────────────────────────────── -->
  <div class="section-intro">

    <!-- Primary headline — positions tokiGig with authority -->
    <h2>We build AI tools that work for your business — with you in control.</h2>

    <!-- WHY NOW beat — names the tension before showing the solution -->
    <p class="section-tension">
      Your competitors are already running AI workforces.
      The question isn't <em>whether</em> to adopt AI —
      it's whether you do it on your terms.
    </p>

  </div>

  <!-- ── Pillar cards ────────────────────────────────────────────────────── -->
  <div class="pillar-grid">

    <!-- ── Card 1: Visibility — Radar icon ──────────────────────────────── -->
    <!-- Fear: AI search is already ranking competitors above you           -->
    <article class="pillar-card">

      <div class="pillar-card__icon" aria-hidden="true">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Concentric range rings — like a real radar scope -->
          <circle cx="26" cy="26" r="22" stroke="#3d6b35" stroke-width="1"   opacity="0.35"/>
          <circle cx="26" cy="26" r="15" stroke="#3d6b35" stroke-width="1"   opacity="0.5"/>
          <circle cx="26" cy="26" r="8"  stroke="#5a8f4e" stroke-width="1"   opacity="0.7"/>
          <!-- Crosshair lines -->
          <line x1="26" y1="4"  x2="26" y2="48" stroke="#3d6b35" stroke-width="0.5" opacity="0.3"/>
          <line x1="4"  y1="26" x2="48" y2="26" stroke="#3d6b35" stroke-width="0.5" opacity="0.3"/>
          <!-- Rotating sweep wedge — spins around center -->
          <g class="radar-sweep">
            <path d="M26 26 L26 4 A22 22 0 0 1 45.6 34.8 Z" fill="url(#sweep-grad)" opacity="0.55"/>
          </g>
          <!-- Ping dot — fades in/out in sync with sweep -->
          <circle class="radar-ping" cx="35" cy="16" r="3" fill="#a8d888" opacity="0"/>
          <!-- Center dot — the origin point -->
          <circle cx="26" cy="26" r="3"   fill="#7ab66a"/>
          <circle cx="26" cy="26" r="1.2" fill="#e0f5d0"/>
          <defs>
            <!-- Radial gradient gives the sweep wedge a trailing fade -->
            <radialGradient id="sweep-grad" cx="26" cy="26" r="22" gradientUnits="userSpaceOnUse">
              <stop offset="0%"   stop-color="#7ab66a" stop-opacity="0.9"/>
              <stop offset="100%" stop-color="#7ab66a" stop-opacity="0"/>
            </radialGradient>
          </defs>
        </svg>
      </div>

      <!-- Hard fear statement — not a soft question -->
      <p class="pillar-card__fear">AI is already deciding who gets recommended.</p>

      <h3>Visibility</h3>
      <p>Most businesses are invisible to AI search. We scan your site, score your AI readability, and show you exactly where you're being skipped — and what to fix.</p>

    </article>

    <!-- ── Card 2: Trust — Shield icon ───────────────────────────────────── -->
    <!-- Fear: handing control to an AI black box                           -->
    <article class="pillar-card">

      <div class="pillar-card__icon" aria-hidden="true">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Glow layer — slow pulse signals active protection -->
          <path class="shield-glow"
            d="M26 6 L44 13 L44 28 C44 38 34 45 26 48 C18 45 8 38 8 28 L8 13 Z"
            fill="#5a8f4e" opacity="0.18"/>
          <!-- Outer shield body -->
          <path
            d="M26 6 L44 13 L44 28 C44 38 34 45 26 48 C18 45 8 38 8 28 L8 13 Z"
            stroke="#5a8f4e" stroke-width="1.5" fill="none" opacity="0.9"/>
          <!-- Inner shield — adds depth/layering -->
          <path
            d="M26 12 L39 17.5 L39 28 C39 35 32.5 40.5 26 43 C19.5 40.5 13 35 13 28 L13 17.5 Z"
            stroke="#7ab66a" stroke-width="1" fill="none" opacity="0.55"/>
          <!-- Checkmark — represents owner approval / control point -->
          <path d="M19 27 L24 32 L34 21"
            stroke="#a8d888" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </div>

      <p class="pillar-card__fear">You won't hand your business to a black box.</p>

      <h3>Trust</h3>
      <p>Every tokiGig tool keeps you in command. AI handles the execution. You approve what matters. No black boxes. No surprises. No loss of control.</p>

    </article>

    <!-- ── Card 3: Autonomy — Gears icon ─────────────────────────────────── -->
    <!-- Fear: needing to babysit AI or retrain the whole team              -->
    <article class="pillar-card">

      <div class="pillar-card__icon" aria-hidden="true">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Large gear — clockwise rotation -->
          <g class="gear-cw">
            <!-- Gear body ring -->
            <circle cx="28" cy="24" r="9"   stroke="#5a8f4e" stroke-width="1.5" fill="none" opacity="0.85"/>
            <!-- Gear hub -->
            <circle cx="28" cy="24" r="3.5" fill="#5a8f4e" opacity="0.7"/>
            <!-- 8 teeth via rotated rects around the gear center -->
            <rect x="27" y="13" width="2" height="4" rx="1" fill="#5a8f4e" opacity="0.85"/>
            <rect x="27" y="31" width="2" height="4" rx="1" fill="#5a8f4e" opacity="0.85"/>
            <rect x="17" y="23" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85"/>
            <rect x="35" y="23" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85"/>
            <rect x="20.5" y="16.5" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85" transform="rotate(45 28 24)"/>
            <rect x="20.5" y="16.5" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85" transform="rotate(-45 28 24)"/>
            <rect x="20.5" y="16.5" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85" transform="rotate(135 28 24)"/>
            <rect x="20.5" y="16.5" width="4" height="2" rx="1" fill="#5a8f4e" opacity="0.85" transform="rotate(-135 28 24)"/>
          </g>

          <!-- Small gear — counter-clockwise (opposite direction = meshing) -->
          <g class="gear-ccw">
            <circle cx="16" cy="32" r="6"   stroke="#7ab66a" stroke-width="1.2" fill="none" opacity="0.7"/>
            <circle cx="16" cy="32" r="2.2" fill="#7ab66a" opacity="0.6"/>
            <!-- 8 teeth on small gear -->
            <rect x="15" y="25" width="2" height="3" rx="1" fill="#7ab66a" opacity="0.7"/>
            <rect x="15" y="36" width="2" height="3" rx="1" fill="#7ab66a" opacity="0.7"/>
            <rect x="9"  y="31" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7"/>
            <rect x="20" y="31" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7"/>
            <rect x="11" y="27" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7" transform="rotate(45 16 32)"/>
            <rect x="11" y="27" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7" transform="rotate(-45 16 32)"/>
            <rect x="11" y="27" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7" transform="rotate(135 16 32)"/>
            <rect x="11" y="27" width="3" height="2" rx="1" fill="#7ab66a" opacity="0.7" transform="rotate(-135 16 32)"/>
          </g>

          <!-- Mesh point — the contact where both gears meet -->
          <circle cx="22.5" cy="28.5" r="1.5" fill="#a8d888" opacity="0.8"/>
        </svg>
      </div>

      <p class="pillar-card__fear">Your team can't scale manually forever.</p>

      <h3>Autonomy</h3>
      <p>Your workflows run around the clock. Your team stays focused on what humans do best. That's the destination — an AI workforce that doesn't need babysitting. We build the path.</p>

    </article>

  </div>

</section>

<style>
  /* ── Layout ───────────────────────────────────────────────────────────── */
  .pillar-section {
    /* Inherits padding/width from page layout — don't override here */
  }

  /* ── Tension statement ────────────────────────────────────────────────── */
  .section-tension {
    margin-top: 1rem;
    font-size: 1.05rem;
    line-height: 1.6;
    opacity: 0.72;
    max-width: 52ch;
  }

  .section-tension em {
    font-style: italic;
    opacity: 1; /* full opacity on the key word "whether" */
  }

  /* ── Card grid — matches existing layout pattern ──────────────────────── */
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  /* ── Icon container ───────────────────────────────────────────────────── */
  .pillar-card__icon {
    margin-bottom: 1rem;
    /* Glow uses DOS green from locked brand palette */
    filter: drop-shadow(0 0 6px rgba(90, 143, 78, 0.45));
    transition: filter 0.3s ease;
  }

  .pillar-card:hover .pillar-card__icon {
    /* Intensifies on hover — matches neural network node hover behavior */
    filter: drop-shadow(0 0 14px rgba(122, 184, 106, 0.75));
  }

  /* ── Fear hook — hard statement, not a question ───────────────────────── */
  .pillar-card__fear {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-accent, #7ab66a); /* DOS green accent */
    margin: 0 0 0.3rem;
    line-height: 1.3;
  }

  /* ── Card heading — tight spacing after fear hook ─────────────────────── */
  .pillar-card h3 {
    margin-top: 0.15rem;
  }

  /* ── Radar sweep animation ────────────────────────────────────────────── */
  @keyframes radar-sweep {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* transform-origin must match the SVG center point (26,26) */
  .radar-sweep {
    transform-origin: 26px 26px;
    animation: radar-sweep 2.8s linear infinite;
  }

  /* Ping dot fades in and grows as the sweep passes over it */
  @keyframes radar-ping {
    0%   { opacity: 0; r: 3; }
    30%  { opacity: 1; }
    100% { opacity: 0; r: 7; }
  }

  .radar-ping {
    animation: radar-ping 2.8s ease-out infinite;
  }

  /* ── Shield pulse — slow breathe signals active protection ───────────── */
  @keyframes shield-pulse {
    0%, 100% { opacity: 0.18; }
    50%       { opacity: 0.42; }
  }

  .shield-glow {
    animation: shield-pulse 2.4s ease-in-out infinite;
  }

  /* ── Gear rotations — opposite directions to simulate meshing ─────────── */
  @keyframes gear-spin-cw  { from { transform: rotate(0deg); }   to { transform: rotate(360deg); } }
  @keyframes gear-spin-ccw { from { transform: rotate(0deg); }   to { transform: rotate(-360deg); } }

  /* transform-origins match the SVG center of each gear */
  .gear-cw  {
    transform-origin: 28px 24px;
    animation: gear-spin-cw 5s linear infinite;
  }

  .gear-ccw {
    transform-origin: 16px 32px;
    animation: gear-spin-ccw 5s linear infinite;
  }
</style>