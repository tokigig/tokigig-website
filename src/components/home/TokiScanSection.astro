---
const { scanHref } = Astro.props;
---

// TokiScanSection.astro (or replace inline in index.astro)
// Section 4 — tokiScan product preview
// Fixes: brand label turtle case, score color by tier, locked bar visual, report mock polish
---

<div class="section-intro">
  <!-- tokiScan in turtle case per finalized brand convention — never all-caps -->
  <p class="route-kicker">tokiScan</p>
  <h2>Find out if AI can understand and recommend your business — in 60 seconds.</h2>
</div>

<div class="scan-report">

  <!-- ── Score panel ─────────────────────────────────────────────────────── -->
  <!-- Score value gets a data-tier attribute so CSS can color it correctly  -->
  <!-- Tier logic: 0-49 = danger, 50-69 = warning, 70-79 = passing, 80+ = strong -->
  <div class="scan-report__score">
    <div class="scan-report__score-main">
      <span class="scan-report__score-value" data-tier="warning">59</span>
      <span class="scan-report__score-total">/100</span>
    </div>
    <!-- Label should match the tier — "Borderline" is correct for 50-69 -->
    <p class="scan-report__score-label" data-tier="warning">Borderline</p>
  </div>

  <!-- ── Priority issue panel ───────────────────────────────────────────── -->
  <div class="scan-report__issue">
    <p class="scan-report__eyebrow">Priority issue</p>
    <h3>No structured data — AI is guessing at your business</h3>

    <div class="scan-report__action">
      <p class="scan-report__action-label">What to do</p>
      <p>Add structured business markup so AI can identify what you do, who you serve, and how to categorize you.</p>
    </div>
  </div>

  <!-- ── Locked / teaser row ────────────────────────────────────────────── -->
  <!-- Mimics blurred report rows beneath a paywall — intentional, not a glitch -->
  <div class="scan-report__locked">
    <!-- Fake redacted rows — gives the impression of real data underneath -->
    <div class="scan-report__locked-rows" aria-hidden="true">
      <!-- Each fake row simulates a blurred issue line -->
      <div class="scan-report__locked-row"><span></span><span></span></div>
      <div class="scan-report__locked-row"><span></span><span></span></div>
      <div class="scan-report__locked-row"><span></span><span></span></div>
    </div>
    <!-- Gradient overlay fades the fake rows into the CTA text -->
    <div class="scan-report__locked-overlay" aria-hidden="true"></div>
    <!-- CTA label sits on top of the fade -->
    <div class="scan-report__locked-cta">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <!-- Lock icon — reinforces "this content is locked" clearly -->
        <rect x="3" y="6" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <path d="M4.5 6V4.5a2.5 2.5 0 0 1 5 0V6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      </svg>
      <p>+20 more issues in the Pro Report</p>
    </div>
  </div>

</div>

<p class="section-quote section-quote--narrow">
  "Most businesses score under 65 on their first scan. The Pro Report shows exactly what's wrong and what to fix."
</p>

<div class="section-cta">
  <a href={scanHref} class="btn-primary">Run your free scan — takes 60 seconds</a>
  <p>No account required · No credit card · Instant results</p>
</div>

<style>
  /* ── Score color tiers — honest signaling, not false green ───────────── */
  /* These override the global var(--toki-green-lt) on .scan-report__score-value */

  /* 0–49: danger — red, something is badly wrong */
  .scan-report__score-value[data-tier="danger"],
  .scan-report__score-label[data-tier="danger"] {
    color: #EF4444; /* Force-Fail red — used sparingly, only when warranted */
  }

  /* 50–69: warning — amber, borderline territory */
  .scan-report__score-value[data-tier="warning"],
  .scan-report__score-label[data-tier="warning"] {
    color: var(--toki-amber); /* pulls from your existing palette — honest signal */
  }

  /* 70–79: passing — lightened from --toki-amber (#c8a030), no -lt var defined */
  .scan-report__score-value[data-tier="passing"],
  .scan-report__score-label[data-tier="passing"] {
    color: var(--toki-amber-lt);
  }

  /* 80–100: strong — DOS green, AI Ready */
  .scan-report__score-value[data-tier="strong"],
  .scan-report__score-label[data-tier="strong"] {
    color: var(--toki-green-lt); /* Full DOS green — earned, not defaulted to */
  }

  /* ── Locked rows — fake redacted report data ──────────────────────────── */
  /* Replaces the CSS stripe pattern that looked like a rendering glitch     */

  .scan-report__locked {
    position: relative;
    grid-column: 1 / -1;
    min-height: 120px;
    overflow: hidden;
    /* Remove old flex centering — content is now layered via position */
    display: block;
  }

  /* Container for the fake blurred issue rows */
  .scan-report__locked-rows {
    position: absolute;
    inset: 0;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Each fake row — two pill shapes mimicking issue title + severity badge */
  .scan-report__locked-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0.35;
  }

  /* Long pill = issue title text placeholder */
  .scan-report__locked-row span:first-child {
    height: 10px;
    width: 55%;
    border-radius: 999px;
    background: rgba(255,255,255,0.15);
  }

  /* Short pill = severity/badge placeholder */
  .scan-report__locked-row span:last-child {
    height: 10px;
    width: 18%;
    border-radius: 999px;
    background: rgba(255,255,255,0.1);
  }

  /* Gradient overlay — fades the rows down into the CTA, clean not glitchy */
  .scan-report__locked-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--bg-card, #111) 72%
    );
  }

  /* CTA sits at the bottom, on top of the fade */
  .scan-report__locked-cta {
    position: absolute;
    bottom: 1.25rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--text-primary);
  }

  .scan-report__locked-cta svg {
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .scan-report__locked-cta p {
    margin: 0;
    font-size: 14px;
    color: var(--text-primary);
  }
</style>