<canvas id="neural-canvas" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('neural-canvas');
  const wrap = document.getElementById('hero-section');

  if (!(canvas instanceof HTMLCanvasElement) || !(wrap instanceof HTMLElement)) {
    throw new Error('Hero network canvas mount failed.');
  }

  const ctx = canvas.getContext('2d');

  if (!ctx) {
    throw new Error('Hero network canvas context failed.');
  }

  let W, H, nodes = [], edges = [], twinkles = [], pulses = [], t = 0;

  function rnd(a, b) { return a + Math.random() * (b - a); }
  function ri(a, b) { return Math.floor(rnd(a, b)); }

  function init() {
    W = wrap.offsetWidth;
    H = Math.max(wrap.offsetHeight, 420);
    canvas.width = W;
    canvas.height = H;
    nodes = []; edges = []; twinkles = []; pulses = [];

    const netLeft = W * 0.42;
    const netRight = W * 0.99;
    const netTop = H * 0.02;
    const netBottom = H * 0.98;

    const count = W < 500 ? 80 : 140;
    for (let i = 0; i < count; i++) {
      const x = rnd(netLeft, netRight);
      const y = rnd(netTop, netBottom);
      const rightness = (x - netLeft) / (netRight - netLeft);
      const baseR = rnd(0.8, rightness > 0.6 ? 3.5 : 2.2);
      nodes.push({
        x, y, rightness, baseR, r: baseR,
        twinkOff: rnd(0, Math.PI * 2),
        twinkSpd: rnd(0.006, 0.02),
        glowOff: rnd(0, Math.PI * 2),
        glowSpd: rnd(0.008, 0.018),
        alpha: rnd(0.08, 0.18) + rightness * 0.28,
        isKey: rightness > 0.7 && Math.random() > 0.65
      });
    }

    for (let i = 0; i < 8; i++) {
      const x = rnd(W * 0.78, W * 0.96);
      const y = rnd(H * 0.15, H * 0.85);
      const rightness = (x - netLeft) / (netRight - netLeft);
      nodes.push({
        x, y, rightness, baseR: rnd(4, 8), r: 5,
        twinkOff: rnd(0, Math.PI * 2), twinkSpd: rnd(0.005, 0.012),
        glowOff: rnd(0, Math.PI * 2), glowSpd: rnd(0.007, 0.015),
        alpha: rnd(0.5, 0.85), isKey: true
      });
    }

    nodes.push({
      x: W * 0.92, y: H * 0.5,
      baseR: 12, r: 12, rightness: 1,
      twinkOff: 0, twinkSpd: 0.008,
      glowOff: 0, glowSpd: 0.01,
      alpha: 1, isKey: true, isOutput: true
    });

    for (let i = 0; i < nodes.length; i++) {
      const a = nodes[i];
      for (let j = i + 1; j < nodes.length; j++) {
        const b = nodes[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const maxDist = W < 500 ? 80 : 110;
        if (dist < maxDist && Math.random() > 0.55) {
          const avgRight = (a.rightness + b.rightness) / 2;
          edges.push({
            a, b,
            alpha: rnd(0.04, 0.14) + avgRight * 0.12,
            w: rnd(0.3, 0.8) * (0.5 + avgRight * 0.8)
          });
        }
      }
    }
  }

  function drawGlow(x, y, r, color, alpha) {
    const g = ctx.createRadialGradient(x, y, 0, x, y, r);
    if (color === 'blue') {
      g.addColorStop(0, `rgba(74,154,221,${alpha})`);
      g.addColorStop(1, 'rgba(26,74,122,0)');
    } else if (color === 'amb') {
      g.addColorStop(0, `rgba(200,160,48,${alpha})`);
      g.addColorStop(1, 'rgba(122,90,16,0)');
    } else {
      g.addColorStop(0, `rgba(122,184,106,${alpha})`);
      g.addColorStop(1, 'rgba(61,107,53,0)');
    }
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();
  }

  function frame() {
    ctx.clearRect(0, 0, W, H);
    t++;

    for (const e of edges) {
      ctx.beginPath();
      ctx.moveTo(e.a.x, e.a.y);
      ctx.lineTo(e.b.x, e.b.y);
      ctx.strokeStyle = `rgba(61,107,53,${e.alpha})`;
      ctx.lineWidth = e.w;
      ctx.stroke();
    }

    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i];
      p.t += p.spd;
      if (p.t >= 1) { pulses.splice(i, 1); continue; }
      const frac = p.fwd ? p.t : 1 - p.t;
      const x = p.edge.a.x + (p.edge.b.x - p.edge.a.x) * frac;
      const y = p.edge.a.y + (p.edge.b.y - p.edge.a.y) * frac;
      drawGlow(x, y, p.r * 3.5, p.color, 0.45);
      ctx.beginPath();
      ctx.arc(x, y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.color === 'blue' ? 'rgba(74,154,221,1)' : 'rgba(122,184,106,1)';
      ctx.fill();
    }

    for (let i = twinkles.length - 1; i >= 0; i--) {
      const tw = twinkles[i];
      tw.life++;
      if (tw.life >= tw.dur) { twinkles.splice(i, 1); continue; }
      const env = Math.sin((tw.life / tw.dur) * Math.PI);
      const r = tw.node.baseR + (tw.maxR - tw.node.baseR) * env;
      const a = tw.maxA * env;
      drawGlow(tw.node.x, tw.node.y, r * 3, tw.color, a * 0.55);
      ctx.beginPath();
      ctx.arc(tw.node.x, tw.node.y, r, 0, Math.PI * 2);
      const fc = tw.color === 'blue' ? `rgba(100,170,255,${a})` :
        tw.color === 'amb' ? `rgba(220,180,60,${a})` :
        `rgba(168,216,136,${a})`;
      ctx.fillStyle = fc;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(tw.node.x, tw.node.y, r * 0.35, 0, Math.PI * 2);
      ctx.fillStyle = tw.color === 'blue' ? `rgba(220,240,255,${a * 0.9})` :
        tw.color === 'amb' ? `rgba(255,230,140,${a * 0.9})` :
        `rgba(230,255,210,${a * 0.9})`;
      ctx.fill();
    }

    for (const n of nodes) {
      const tw = Math.sin(t * n.twinkSpd + n.twinkOff) * 0.5 + 0.5;
      const gl = Math.sin(t * n.glowSpd + n.glowOff) * 0.5 + 0.5;
      n.r = n.baseR + tw * (n.isOutput ? 3 : n.isKey ? 1.8 : 0.8);
      const a = n.alpha + tw * 0.15;

      if (n.isOutput) {
        drawGlow(n.x, n.y, n.r * 5, 'green', 0.22 + gl * 0.12);
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(29,51,26,${0.6 + gl * 0.2})`; ctx.fill();
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(90,143,78,${0.88 + gl * 0.12})`; ctx.fill();
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 0.42, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(168,216,136,0.92)`; ctx.fill();
      } else if (n.isKey) {
        drawGlow(n.x, n.y, n.r * 3.5, 'green', a * 0.4);
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(90,143,78,${a * 0.9})`; ctx.fill();
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 0.4, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(168,216,136,${a * 0.8})`; ctx.fill();
      } else {
        if (a > 0.15) drawGlow(n.x, n.y, n.r * 2.5, 'green', a * 0.25);
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(90,143,78,${a})`; ctx.fill();
      }
    }

    const isLightTheme = document.documentElement.getAttribute('data-theme') === 'light';
    const maskColor = isLightTheme ? '245,244,240' : '8,8,8';

    const mask = ctx.createLinearGradient(0, 0, W, 0);
    mask.addColorStop(0, `rgba(${maskColor},1)`);
    mask.addColorStop(0.28, `rgba(${maskColor},1)`);
    mask.addColorStop(0.44, `rgba(${maskColor},0.92)`);
    mask.addColorStop(0.55, `rgba(${maskColor},0.4)`);
    mask.addColorStop(0.68, `rgba(${maskColor},0.0)`);
    ctx.fillStyle = mask;
    ctx.fillRect(0, 0, W, H);

    requestAnimationFrame(frame);
  }

  function start() {
    W = wrap.offsetWidth;
    H = Math.max(wrap.offsetHeight, 420);
    canvas.width = W;
    canvas.height = H;
    init();
    frame();
  }

  setInterval(() => {
    if (twinkles.length < 12) {
      const pool = nodes.filter((n) => n.rightness > 0.3);
      if (!pool.length) return;
      const n = pool[ri(0, pool.length)];
      const roll = Math.random();
      twinkles.push({
        node: n, life: 0, dur: ri(50, 110),
        color: roll > 0.72 ? 'blue' : roll > 0.88 ? 'amb' : 'green',
        maxR: n.baseR * rnd(2.2, 4.5),
        maxA: rnd(0.65, 1.0)
      });
    }
  }, 350);

  setInterval(() => {
    if (pulses.length < 10 && edges.length > 0) {
      const e = edges[ri(0, edges.length)];
      pulses.push({
        edge: e, t: 0,
        spd: rnd(0.007, 0.018),
        r: rnd(2, 3.5),
        color: Math.random() > 0.65 ? 'blue' : 'green',
        fwd: Math.random() > 0.5
      });
    }
  }, 280);

  if (document.readyState === 'complete') { setTimeout(start, 80); }
  else { window.addEventListener('load', () => setTimeout(start, 80)); }
  window.addEventListener('resize', () => {
    clearTimeout(window._rt);
    window._rt = setTimeout(start, 200);
  });

  window.addEventListener('storage', start);

  const themeObserver = new MutationObserver(start);
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
});

</script>
