<script define:vars={{ appScanEntry: APP_SCAN_ENTRY }}>
  const form = document.getElementById('homepage-scan-form');
  const input = form?.querySelector('input[name="url"]');
  const error = document.getElementById('homepage-scan-error');

  function normalizeDomain(value) {
    const trimmed = value.trim();
    if (!trimmed) {
      return null;
    }

    const candidate = trimmed.match(/^https?:\/\//i) ? trimmed : `https://${trimmed}`;

    try {
      const parsed = new URL(candidate);
      const hostname = parsed.hostname.toLowerCase();

      if (!hostname || !hostname.includes('.') || hostname.includes(' ')) {
        return null;
      }

      return hostname;
    } catch {
      return null;
    }
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const normalized = normalizeDomain(input instanceof HTMLInputElement ? input.value : '');

    if (!normalized) {
      if (error) {
        error.textContent = 'Enter a valid domain like yourbusiness.com';
      }
      if (input instanceof HTMLInputElement) {
        input.setAttribute('aria-invalid', 'true');
        input.focus();
      }
      return;
    }

    if (error) {
      error.textContent = '';
    }
    if (input instanceof HTMLInputElement) {
      input.removeAttribute('aria-invalid');
    }

    const destination = new URL(appScanEntry);
    destination.searchParams.set('source', 'homepage-final');
    destination.searchParams.set('domain', normalized);
    destination.searchParams.set('url', normalized);

    window.location.assign(destination.toString());
  });
</script>
