---
import MarketingShell from '../components/MarketingShell.astro';
import HeroNetwork from '../components/HeroNetwork.astro';
import { APP_SCAN_ENTRY, buildScanHref } from '../lib/scan-flow';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'tokigig',
  url: 'https://tokigig.com',
  logo: 'https://tokigig.com/logos/tokigig-logo-lockup-light-bg.svg',
  sameAs: ['https://x.com/tokiOSHQ'],
  description:
    'tokigig builds AI tools for business operators, including tokiscan for AI visibility and toki-os as the underlying operating system.',
};
---

<MarketingShell
  title="tokigig - AI visibility for your business"
  description="AI is recommending businesses to your customers right now. Find out if yours is showing up - or getting skipped."
  currentPath="/"
  schema={organizationSchema}
>
  <section class="homepage-hero" id="hero-section">
    <HeroNetwork />
    <div class="homepage-hero__layout">
      <div class="homepage-hero__copy">
        <p class="route-kicker">AI VISIBILITY</p>
        <h1 class="homepage-hero__headline">
          <span>AI is recommending</span>
          <span>businesses to your</span>
          <span class="headline-accent">customers right now.</span>
        </h1>
        <p class="homepage-hero__subhead">Is yours showing up — or getting skipped?</p>
        <div class="route-actions homepage-hero__actions">
          <a href={buildScanHref('homepage-hero')} class="btn-primary">run a free scan</a>
          <a href="#tokiscan-in-action" class="btn-secondary">see how it works</a>
        </div>
        <p class="homepage-hero__powered">
          powered by <a href="/os">toki-os</a>
        </p>
      </div>

      <div class="homepage-hero__network" aria-hidden="true"></div>
    </div>
  </section>

  <section id=”visibility-gap”>
    <div class=”vgap-inner”>
      <p class=”vgap-eyebrow”>the visibility gap</p>
      <h2 class=”vgap-headline”>What AI <span class=”accent”>actually</span> sees on your site</h2>
      <p class=”vgap-sub”>Most businesses assume AI understands them. Most are wrong.</p>

      <div class=”vgap-panels”>
        <div class=”vgap-left”>
          <p class=”vgap-panel-label vgap-panel-label--green”>
            <span class=”vgap-dot vgap-dot--green”></span>
            What you think AI sees
          </p>
          <ul class=”vgap-items”>
            <li class=”vgap-check-item”>
              <span class=”vgap-check-icon”>
                <svg viewBox=”0 0 12 12” fill=”none” xmlns=”http://www.w3.org/2000/svg”>
                  <path d=”M2 6l3 3 5-5” stroke=”#5a8f4e” stroke-width=”1.5” stroke-linecap=”round” stroke-linejoin=”round”/>
                </svg>
              </span>
              <div>
                <div class=”vgap-item-text”>Beautiful product photos</div>
                <div class=”vgap-item-sub”>High-quality visuals throughout</div>
              </div>
            </li>
            <li class=”vgap-check-item”>
              <span class=”vgap-check-icon”>
                <svg viewBox=”0 0 12 12” fill=”none” xmlns=”http://www.w3.org/2000/svg”>
                  <path d=”M2 6l3 3 5-5” stroke=”#5a8f4e” stroke-width=”1.5” stroke-linecap=”round” stroke-linejoin=”round”/>
                </svg>
              </span>
              <div>
                <div class=”vgap-item-text”>Your brand story &amp; expertise</div>
                <div class=”vgap-item-sub”>Years of reputation on every page</div>
              </div>
            </li>
            <li class=”vgap-check-item”>
              <span class=”vgap-check-icon”>
                <svg viewBox=”0 0 12 12” fill=”none” xmlns=”http://www.w3.org/2000/svg”>
                  <path d=”M2 6l3 3 5-5” stroke=”#5a8f4e” stroke-width=”1.5” stroke-linecap=”round” stroke-linejoin=”round”/>
                </svg>
              </span>
              <div>
                <div class=”vgap-item-text”>Glowing customer reviews</div>
                <div class=”vgap-item-sub”>5-star social proof everywhere</div>
              </div>
            </li>
            <li class=”vgap-check-item”>
              <span class=”vgap-check-icon”>
                <svg viewBox=”0 0 12 12” fill=”none” xmlns=”http://www.w3.org/2000/svg”>
                  <path d=”M2 6l3 3 5-5” stroke=”#5a8f4e” stroke-width=”1.5” stroke-linecap=”round” stroke-linejoin=”round”/>
                </svg>
              </span>
              <div>
                <div class=”vgap-item-text”>Clear pricing and offers</div>
                <div class=”vgap-item-sub”>Competitive rates, easy to find</div>
              </div>
            </li>
          </ul>
          <div class=”vgap-confidence”>
            <div class=”vgap-bar-track”>
              <div class=”vgap-bar-fill” style=”width: 85%; background: #5a8f4e;”></div>
            </div>
            <span class=”vgap-bar-label” style=”color: #5a8f4e;”>High — owner assumes strong visibility</span>
          </div>
        </div>

        <div class=”vgap-center”>
          <span class=”vgap-vs”>vs</span>
        </div>

        <div class=”vgap-right”>
          <p class=”vgap-panel-label vgap-panel-label--red”>
            <span class=”vgap-dot vgap-dot--red”></span>
            What AI actually extracts
          </p>
          <ul class=”vgap-terminal-items”>
            <li class=”vgap-terminal-item”>
              <span class=”vgap-prompt”>&gt;</span>
              <span class=”vgap-key”>content_status</span>
              <span class=”vgap-badge vgap-badge--grey”>Loading...</span>
            </li>
            <li class=”vgap-terminal-item”>
              <span class=”vgap-prompt”>&gt;</span>
              <span class=”vgap-key”>structured_data</span>
              <span class=”vgap-badge vgap-badge--red”>none detected</span>
            </li>
            <li class=”vgap-terminal-item”>
              <span class=”vgap-prompt”>&gt;</span>
              <span class=”vgap-key”>business_type</span>
              <span class=”vgap-badge vgap-badge--amber”>unclear</span>
            </li>
            <li class=”vgap-terminal-item”>
              <span class=”vgap-prompt”>&gt;</span>
              <span class=”vgap-key”>recommendation_confidence</span>
              <span class=”vgap-badge vgap-badge--red”>low — 18 / 100</span>
            </li>
          </ul>
          <div class=”vgap-confidence”>
            <div class=”vgap-bar-track”>
              <div class=”vgap-bar-fill” style=”width: 18%; background: #ef4444; opacity: 0.65;”></div>
            </div>
            <span class=”vgap-bar-label” style=”color: rgba(239,68,68,0.75);”>Effectively invisible to AI recommendation engines</span>
          </div>
        </div>
      </div>

      <div class=”vgap-verdicts”>
        <div class=”vgap-verdict-1”>
          <strong>AI can’t recommend what it can’t understand.</strong> Most businesses are invisible to AI without ever knowing it — not because their product is weak, but because their site doesn’t speak AI’s language. And AI search is no longer the future. It’s already the primary discovery layer for over 1.5 billion people.
        </div>
        <div class=”vgap-verdict-2”>
          <p class=”vgap-quote”>”Search is evolving into an <em>agent manager</em> — users will have many threads running, completing tasks rather than browsing results. The businesses that AI can understand will be the ones it recommends.”</p>
          <div class=”vgap-attribution”>
            <span class=”vgap-attribution-text”>Sundar Pichai, CEO — Google &amp; Alphabet, April 2026</span>
            <span class=”vgap-attr-badge”>Google I/O 2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section" id="builds">
    <div class="section-intro">
      <h2>We build AI tools that work for your business — with you in control.</h2>
    </div>
    <div class="pillar-grid">
      <article class="pillar-card">
        <div class="pillar-card__icon">◌</div>
        <h3>Visibility</h3>
        <p>Can AI find, understand, and recommend you? Most businesses don’t know the answer. We show you.</p>
      </article>
      <article class="pillar-card">
        <div class="pillar-card__icon">◇</div>
        <h3>Trust</h3>
        <p>Every tokigig tool keeps the operator in control. AI does the work. You make the calls.</p>
      </article>
      <article class="pillar-card">
        <div class="pillar-card__icon">△</div>
        <h3>Autonomy</h3>
        <p>Your business running AI workflows without constant oversight. That’s the destination. We build the path.</p>
      </article>
    </div>
  </section>

  <section class="home-section home-section--scan" id="tokiscan-in-action">
    <div class="section-intro">
      <p class="route-kicker">TOKISCAN</p>
      <h2>Find out if AI can understand and recommend your business — in 60 seconds.</h2>
    </div>
    <div class="scan-report">
      <div class="scan-report__score">
        <div class="scan-report__score-main">
          <span class="scan-report__score-value">59</span>
          <span class="scan-report__score-total">/100</span>
        </div>
        <p class="scan-report__score-label">Borderline</p>
      </div>

      <div class="scan-report__issue">
        <p class="scan-report__eyebrow">Priority issue</p>
        <h3>No structured data — AI is guessing at your business</h3>
        <div class="scan-report__action">
          <p class="scan-report__action-label">What to do</p>
          <p>Add structured business markup so AI can identify what you do, who you serve, and how to categorize you.</p>
        </div>
      </div>

      <div class="scan-report__locked">
        <div class="scan-report__locked-blur"></div>
        <p>+20 more issues in the Pro Report</p>
      </div>
    </div>

    <p class="section-quote section-quote--narrow">“Most businesses score under 65 on their first scan. The Pro Report shows exactly what’s wrong and what to fix.”</p>
    <div class="section-cta">
      <a href={buildScanHref('homepage-section-4')} class="btn-primary">Run your free scan — takes 60 seconds</a>
      <p>No account required · No credit card · Instant results</p>
    </div>
  </section>

  <section class="home-section">
    <div class="section-intro">
      <h2>tokiscan is just the beginning.</h2>
      <p>We’re building a suite of AI tools for business operators — each one designed to make your business more visible, more trusted, and more capable. No technical expertise required.</p>
    </div>
    <div class="module-list" aria-label="Upcoming modules">
      <article class="module-row module-row--active">
        <div>
          <h3>tokiscan</h3>
          <p>AI visibility diagnostic</p>
        </div>
        <span>Available now</span>
      </article>
      <article class="module-row">
        <div>
          <h3>tokipatch</h3>
          <p>AI-powered fix implementation</p>
        </div>
        <span>Coming soon</span>
      </article>
      <article class="module-row">
        <div>
          <h3>tokiworker</h3>
          <p>Autonomous AI workforce</p>
        </div>
        <span>Coming soon</span>
      </article>
    </div>
  </section>

  <section class="trust-band">
    <div class="trust-band__inner">
      <h2>AI that won’t act without you.</h2>
      <p class="trust-band__subhead">Autonomous but accountable.</p>
      <p class="trust-band__body">Every tokigig tool is built on a simple principle: AI does the work, you make the calls. No black boxes. No surprises. No agents going rogue. Just your business, running smarter — with you in control.</p>
      <p class="trust-band__foot">Built on <a href="/os">toki-os</a> — an open AI operating system anyone can inspect, extend, and trust.</p>
    </div>
  </section>

  <section class="home-section home-section--final">
    <div class="section-intro section-intro--center">
      <h2>Find out where you stand.</h2>
      <p>Most businesses are surprised by what AI can’t understand about them.</p>
    </div>
    <form class="final-cta" id="homepage-scan-form" action={buildScanHref('homepage-final')} method="GET" novalidate>
      <input type="text" name="url" placeholder="yourbusiness.com" aria-label="Business URL" autocomplete="url" />
      <button type="submit">Run free AI scan</button>
    </form>
    <p class="final-cta__error" id="homepage-scan-error" aria-live="polite"></p>
    <p class="final-cta__micro">No account required · Takes 60 seconds</p>
    <p class="final-cta__secondary">Want the full platform? <a href="https://apps.tokigig.com">Get early access →</a></p>
  </section>
</MarketingShell>

