---
import MarketingShell from '../components/MarketingShell.astro';
import HomeHero from '../components/home/HomeHero.astro';
import VisibilityGap from '../components/home/VisibilityGap.astro';
import { APP_SCAN_ENTRY, buildScanHref } from '../lib/scan-flow';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'tokiGig',
  url: 'https://tokigig.com',
  logo: 'https://tokigig.com/logos/tokigig-logo-lockup-light-bg.svg',
  sameAs: ['https://x.com/tokiOSHQ'],
  description:
    'tokiGig builds AI tools for business operators, including tokiScan for AI visibility and toki-OS as the underlying operating system.',
};
---

<MarketingShell
  title="tokiGig - AI visibility for your business"
  description="AI is recommending businesses to your customers right now. Find out if yours is showing up - or getting skipped."
  currentPath="/"
  schema={organizationSchema}
>
  <HomeHero />

  <VisibilityGap />

  <section class="home-section" id="builds">
    <div class="section-intro">
      <h2>We build AI tools that work for your business — with you in control.</h2>
    </div>

    <div class="pillar-grid">
      <article class="pillar-card">
        <div class="pillar-card__icon">◌</div>
        <h3>Visibility</h3>
        <p>Can AI find, understand, and recommend you? Most businesses don’t know the answer. We show you.</p>
      </article>

      <article class="pillar-card">
        <div class="pillar-card__icon">◇</div>
        <h3>Trust</h3>
        <p>Every tokiGig tool keeps the business owner in control. AI does the work. You make the calls.</p>
      </article>

      <article class="pillar-card">
        <div class="pillar-card__icon">△</div>
        <h3>Autonomy</h3>
        <p>Your business running AI workflows without constant oversight. That’s the destination. We build the path.</p>
      </article>
    </div>
  </section>

  <section class="home-section home-section--scan" id="tokiScan-in-action">
    <div class="section-intro">
      <p class="route-kicker">TOKISCAN</p>
      <h2>Find out if AI can understand and recommend your business — in 60 seconds.</h2>
    </div>

    <div class="scan-report">
      <div class="scan-report__score">
        <div class="scan-report__score-main">
          <span class="scan-report__score-value">59</span>
          <span class="scan-report__score-total">/100</span>
        </div>
        <p class="scan-report__score-label">Borderline</p>
      </div>

      <div class="scan-report__issue">
        <p class="scan-report__eyebrow">Priority issue</p>
        <h3>No structured data — AI is guessing at your business</h3>

        <div class="scan-report__action">
          <p class="scan-report__action-label">What to do</p>
          <p>Add structured business markup so AI can identify what you do, who you serve, and how to categorize you.</p>
        </div>
      </div>

      <div class="scan-report__locked">
        <div class="scan-report__locked-blur"></div>
        <p>+20 more issues in the Pro Report</p>
      </div>
    </div>

    <p class="section-quote section-quote--narrow">
      “Most businesses score under 65 on their first scan. The Pro Report shows exactly what’s wrong and what to fix.”
    </p>

    <div class="section-cta">
      <a href={buildScanHref('homepage-section-4')} class="btn-primary">Run your free scan — takes 60 seconds</a>
      <p>No account required · No credit card · Instant results</p>
    </div>
  </section>

  <section class="home-section">
    <div class="section-intro">
      <h2>tokiScan is just the beginning.</h2>
      <p>
        We’re building a suite of AI tools for business owners — each one designed to make your business more visible,
        more trusted, and more capable. No technical expertise required.
      </p>
    </div>

    <div class="module-list" aria-label="Upcoming modules">
      <article class="module-row module-row--active">
        <div>
          <h3>tokiScan</h3>
          <p>AI visibility diagnostic</p>
        </div>
        <span>Available now</span>
      </article>

      <article class="module-row">
        <div>
          <h3>tokiPatch</h3>
          <p>AI-powered fix implementation</p>
        </div>
        <span>Coming soon</span>
      </article>

      <article class="module-row">
        <div>
          <h3>tokiWorker</h3>
          <p>Autonomous AI workforce</p>
        </div>
        <span>Coming soon</span>
      </article>
    </div>
  </section>

  <section class="trust-band">
    <div class="trust-band__inner">
      <h2>AI that won’t act without you.</h2>
      <p class="trust-band__subhead">Autonomous but accountable.</p>
      <p class="trust-band__body">
        Every tokiGig tool is built on a simple principle: AI does the work, you make the calls. No black boxes.
        No surprises. No agents going rogue. Just your business, running smarter — with you in control.
      </p>
      <p class="trust-band__foot">
        Built on <a href="/os">toki-OS</a> — an open AI operating system anyone can inspect, extend, and trust.
      </p>
    </div>
  </section>

  <section class="home-section home-section--final">
    <div class="section-intro section-intro--center">
      <h2>Find out where you stand.</h2>
      <p>Most businesses are surprised by what AI can’t understand about them.</p>
    </div>

    <form class="final-cta" id="homepage-scan-form" action={buildScanHref('homepage-final')} method="GET" novalidate>
      <input type="text" name="url" placeholder="yourbusiness.com" aria-label="Business URL" autocomplete="url" />
      <button type="submit">Run free AI scan</button>
    </form>

    <p class="final-cta__error" id="homepage-scan-error" aria-live="polite"></p>
    <p class="final-cta__micro">No account required · Takes 60 seconds</p>
    <p class="final-cta__secondary">
      Want the full platform? <a href="https://apps.tokigig.com">Get early access →</a>
    </p>
  </section>
</MarketingShell>

<script define:vars={{ appScanEntry: APP_SCAN_ENTRY }}>
  const form = document.getElementById('homepage-scan-form');
  const input = form?.querySelector('input[name="url"]');
  const error = document.getElementById('homepage-scan-error');

  function normalizeDomain(value) {
    const trimmed = value.trim();

    if (!trimmed) {
      return null;
    }

    const candidate = trimmed.match(/^https?:\/\//i) ? trimmed : `https://${trimmed}`;

    try {
      const parsed = new URL(candidate);
      const hostname = parsed.hostname.toLowerCase();

      if (!hostname || !hostname.includes('.') || hostname.includes(' ')) {
        return null;
      }

      return hostname;
    } catch {
      return null;
    }
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const normalized = normalizeDomain(input instanceof HTMLInputElement ? input.value : '');

    if (!normalized) {
      if (error) {
        error.textContent = 'Enter a valid domain like yourbusiness.com';
      }

      if (input instanceof HTMLInputElement) {
        input.setAttribute('aria-invalid', 'true');
        input.focus();
      }

      return;
    }

    if (error) {
      error.textContent = '';
    }

    if (input instanceof HTMLInputElement) {
      input.removeAttribute('aria-invalid');
    }

    const destination = new URL(appScanEntry);
    destination.searchParams.set('source', 'homepage-final');
    destination.searchParams.set('domain', normalized);
    destination.searchParams.set('url', normalized);

    window.location.assign(destination.toString());
  });
</script>